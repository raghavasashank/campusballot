DATABASE_URL="postgresql://user:password@localhost:5432/campusballot?schema=public"
ALLOWED_EMAIL_DOMAIN="college.edu"
ADMIN_EMAILS="admin@college.edu"
SESSION_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""

# Optional: without this, magic links are logged to the console instead of
# emailed (fine for local dev). Sign up at resend.com (free tier) for an API
# key. Sends over HTTPS, not SMTP — deliberately, since cloud platforms often
# block outbound SMTP ports as an anti-spam measure.
RESEND_API_KEY=""
# Optional: defaults to CampusBallot <onboarding@resend.dev> (Resend's shared
# test sender, works without verifying your own domain). Verify a real
# domain in Resend and set this once you have one.
RESEND_FROM=""

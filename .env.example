DATABASE_URL="postgresql://user:password@localhost:5432/campusballot?schema=public"
ALLOWED_EMAIL_DOMAIN="college.edu"
ADMIN_EMAILS="admin@college.edu"
SESSION_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""

# Optional: without these, magic links are logged to the console instead of
# emailed (fine for local dev). Set all four to send real email via SMTP —
# e.g. Gmail: host smtp.gmail.com, port 587, an app-specific password (not
# your regular password) as SMTP_PASS.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Optional: defaults to SMTP_USER if unset.
SMTP_FROM=""
